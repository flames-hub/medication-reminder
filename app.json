{
  "expo": {
    "name": "のみごろ",
    "slug": "medication-reminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.tama.medreminder",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of your medication",
        "NSPhotoLibraryUsageDescription": "Select photos of your medication",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tama.medreminder",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-localization",
      "expo-image-picker"
    ],
    "updates": {
      "url": "https://u.expo.dev/6e419564-2e08-4278-8fc8-45d9d57393f6",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "6e419564-2e08-4278-8fc8-45d9d57393f6"
      }
    },
    "owner": "tama_lab"
  }
}
